{
  "manifest_version": 3,
  "name": "oh-my-chh",
  "short_name": "oh-my-chh",
  "version": "0.1.7",
  "description": "Enhances the Chiphell forum interface and browsing experience with customizable UI themes.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "oh-my-chh",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/chh-icon-16.png",
      "32": "icons/chh-icon-32.png",
      "48": "icons/chh-icon-48.png",
      "128": "icons/chh-icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chiphell.com/*"
      ],
      "css": [
        "content/preflight.css"
      ],
      "js": [
        "content/main.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "themes/*/index.css",
        "themes/*/preflight.css",
        "themes/*/routes/*.css",
        "themes/*/fonts/*"
      ],
      "matches": [
        "https://www.chiphell.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/chh-icon-16.png",
    "32": "icons/chh-icon-32.png",
    "48": "icons/chh-icon-48.png",
    "128": "icons/chh-icon-128.png"
  }
}
