{
  "name": "oh-my-chh",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "Chiphell.com UI/UX reskin with the Liquid Glass theme.",
  "scripts": {
    "build": "node scripts/build-extension.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:css": "node scripts/check-css-scope.mjs",
    "verify": "npm run lint:css && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/chrome": "latest",
    "@types/node": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
