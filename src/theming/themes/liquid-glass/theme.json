{
  "id": "liquid-glass",
  "name": "Liquid Glass",
  "version": "0.1.0",
  "description": "Latest modern-minimal liquid glass redesign with reconstructed Chiphell header, search and quick navigation surfaces.",
  "styleFamily": "liquid-glass",
  "entrypoints": {
    "preflight": "preflight.css",
    "index": "index.css",
    "routes": {
      "thread-detail": "routes/thread-detail.css",
      "thread-list": "routes/thread-list.css",
      "forum-index": "routes/forum-index.css",
      "portal-home": "routes/portal-home.css",
      "compose": "routes/compose.css",
      "settings": "routes/settings.css",
      "messages": "routes/messages.css",
      "profile": "routes/profile.css",
      "article-view": "routes/article-view.css"
    }
  },
  "tokens": {},
  "capabilities": {
    "scopedSelectors": true,
    "crossThemeImports": false,
    "responsive": true,
    "reducedMotion": true,
    "requiresReloadOnSwitch": true,
    "legacyRootClass": "chh-liquid-glass",
    "glassReductionAttribute": "data-omchh-reduce-glass"
  },
  "routes": [
    "portal-home",
    "forum-index",
    "thread-list",
    "thread-detail",
    "article-view",
    "profile",
    "settings",
    "messages",
    "compose",
    "unknown"
  ]
}
